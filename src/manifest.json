{
	"manifest_version": 3,
	"name": "Letterboxd Review Extension",
	"description": "Improves the Letterboxd review experience",
	"version": "1.0",
	"icons": {
		"16": "images/icon-16.png",
		"32": "images/icon-32.png",
		"48": "images/icon-48.png",
		"128": "images/icon-128.png"
	},
	"content_scripts": [
		{
			"matches": ["*://*.letterboxd.com/*"],
			"js": ["index.js"],
			"css": ["styles.css"]
		}
	]
}
